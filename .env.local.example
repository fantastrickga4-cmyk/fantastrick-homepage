# 판타스트릭 홈페이지 환경변수 예시
# 이 파일을 복사해 ".env.local" 로 만들고 실제 값을 채우세요. (.env.local 은 깃에 올라가지 않음)

# Supabase (예약·리뷰 데이터베이스) — 무료
# 대시보드: https://supabase.com → 프로젝트 → Settings → API
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...   # service_role 키 (비밀! 절대 공개 X)

# (나중에) 토스페이먼츠 — 예약금 결제
# TOSS_SECRET_KEY=
# NEXT_PUBLIC_TOSS_CLIENT_KEY=

# 알리고 SMS — 자동 문자 발송 (알림톡 실패 시 대체발송에도 사용)
# 마이페이지: https://smartsms.aligo.in → API 연동 → 인증키 발급
# ALIGO_API_KEY=
# ALIGO_USER_ID=            # 알리고 로그인 아이디
# ALIGO_SENDER=            # 사전 등록한 발신번호 (예: 025551234)

# 카카오 알림톡 (알리고 경유) — 예약 안내를 카톡으로. 위 ALIGO_* 3개도 함께 필요.
# 준비: 카카오 비즈니스 채널 개설 → 알리고 '카카오 알림톡'에서 발신프로필 등록 → 템플릿 3종 심사승인
# ALIGO_KAKAO_SENDERKEY=    # 발신프로필 키 (senderkey)
# ALIGO_KAKAO_TPL_CONFIRM=  # 확정 안내 템플릿 코드
# ALIGO_KAKAO_TPL_CANCEL=   # 취소 안내 템플릿 코드
# ALIGO_KAKAO_TPL_REMINDER= # 리마인더 템플릿 코드
